<h4 class="ui top attached header">
	{{ctx.Locale.Tr "Edit OAuth2 Application"}}
</h4>
<div class="ui attached segment">
	<p>{{ctx.Locale.Tr "OAuth2 applications gives your third-party application access to user accounts on this instance."}}</p>
</div>
<div class="ui attached segment form ignore-dirty">
	{{.CsrfTokenHtml}}
	<div class="field">
		<label for="client-id">{{ctx.Locale.Tr "Client ID"}}</label>
		<input id="client-id" readonly value="{{.App.ClientID}}">
	</div>
	{{if .ClientSecret}}
		<div class="field">
			<label for="client-secret">{{ctx.Locale.Tr "Client Secret"}}</label>
			<input id="client-secret" type="text" readonly value="{{.ClientSecret}}">
		</div>
	{{else}}
		<div class="field">
			<label for="client-secret">{{ctx.Locale.Tr "Client Secret"}}</label>
			<input id="client-secret" type="password" readonly value="averysecuresecret">
		</div>
	{{end}}
	<div class="item">
		<!-- TODO add regenerate secret functionality */ -->
		<form class="ui form ignore-dirty" action="{{.FormActionPath}}/regenerate_secret" method="post">
			{{.CsrfTokenHtml}}
			{{ctx.Locale.Tr "Lost your secret?"}}
			<button class="ui mini button tw-ml-2" type="submit">{{ctx.Locale.Tr "Regenerate Secret"}}</button>
		</form>
	</div>
</div>
<div class="ui bottom attached segment">
	<form class="ui form ignore-dirty" action="{{.FormActionPath}}" method="post">
		{{.CsrfTokenHtml}}
		<div class="field {{if .Err_AppName}}error{{end}}">
			<label for="application-name">{{ctx.Locale.Tr "Application Name"}}</label>
			<input id="application-name" value="{{.App.Name}}" name="application_name" required maxlength="255">
		</div>
		<div class="field {{if .Err_RedirectURI}}error{{end}}">
			<label for="redirect-uris">{{ctx.Locale.Tr "Redirect URIs. Please use a new line for every URI."}}</label>
			<textarea name="redirect_uris" id="redirect-uris" required>{{StringUtils.Join .App.RedirectURIs "\n"}}</textarea>
		</div>
		<div class="field {{if .Err_ConfidentialClient}}error{{end}}">
			<div class="ui checkbox">
				<label>{{ctx.Locale.Tr "Confidential Client. Select for apps that keep the secret confidential, such as web apps. Do not select for native apps, including desktop and mobile apps."}}</label>
				<input class="disable-setting" type="checkbox" name="confidential_client" data-target="#skip-secondary-authorization" {{if .App.ConfidentialClient}}checked{{end}}>
			</div>
		</div>
		<div class="field {{if .Err_SkipSecondaryAuthorization}}error{{end}} {{if .App.ConfidentialClient}}disabled{{end}}" id="skip-secondary-authorization">
			<div class="ui checkbox">
				<label>{{ctx.Locale.Tr "Skip authorization for public clients after granting access once. <strong>May pose a security risk.</strong>"}}</label>
				<input type="checkbox" name="skip_secondary_authorization" {{if .App.SkipSecondaryAuthorization}}checked{{end}}>
			</div>
		</div>
		<button class="ui primary button">
			{{ctx.Locale.Tr "Save"}}
		</button>
	</form>
</div>
