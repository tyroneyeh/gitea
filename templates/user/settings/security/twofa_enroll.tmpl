{{template "user/settings/layout_head" (dict "ctxData" . "pageClass" "user settings twofa")}}
	<div class="user-setting-content">
		<h4 class="ui top attached header">
			{{ctx.Locale.Tr "Enroll in Two-Factor Authentication"}}
		</h4>
		<div class="ui attached segment">
			<p>{{ctx.Locale.Tr "Scan this image with your authentication application:"}}</p>
			<img src="{{.QrUri}}" alt="{{.TwofaSecret}}">
			<p>{{ctx.Locale.Tr "Or enter the secret: %s" .TwofaSecret}}</p>
			<p>{{ctx.Locale.Tr "And enter the passcode shown in the application:"}}</p>
			<form class="ui form" action="{{.Link}}" method="post">
				{{.CsrfTokenHtml}}
				<div class="inline required field {{if .Err_Passcode}}error{{end}}">
					<label for="passcode">{{ctx.Locale.Tr "Passcode"}}</label>
					<input id="passcode" name="passcode" autofocus required>
				</div>
				<div class="inline field">
					<label></label>
					<button class="ui primary button">{{ctx.Locale.Tr "Verify"}}</button>
				</div>
			</form>
		</div>
	</div>

{{template "user/settings/layout_footer" .}}
