{{template "base/head" .}}
<div role="main" aria-label="{{.Title}}" class="page-content user activate">
	<div class="ui middle very relaxed page grid">
		<div class="column">
			<form class="ui form tw-max-w-2xl tw-m-auto">
				<h2 class="ui top attached header">
					{{ctx.Locale.Tr "Sign-In Prohibited"}}
				</h2>
				<div class="ui attached segment">
					<p>{{ctx.Locale.Tr "Your account is prohibited from signing in. Please contact your site administrator."}}</p>
				</div>
			</form>
		</div>
	</div>
</div>
{{template "base/footer" .}}
