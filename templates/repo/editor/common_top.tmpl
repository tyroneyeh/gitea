{{if .CommitFormOptions.WillSubmitToFork}}
<div class="ui blue message">
	{{$repoLinkHTML := HTMLFormat `<a href="%s">%s</a>` .CommitFormOptions.TargetRepo.Link .CommitFormOptions.TargetRepo.FullName}}
	{{ctx.Locale.Tr "You cannot edit this repository directly. The changes will be written to your fork <b>%s</b>, so you can create a pull request." $repoLinkHTML}}
</div>
{{end}}
