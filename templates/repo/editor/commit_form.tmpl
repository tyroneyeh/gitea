<div class="commit-form-wrapper">
	{{ctx.AvatarUtils.Avatar .SignedUser 40 "commit-avatar"}}
	<div class="commit-form avatar-content-left-arrow">
		<h3>
		{{- if .CommitFormOptions.WillSign}}
			<span data-tooltip-content="{{ctx.Locale.Tr "This commit will be signed with key \"%s\"." .CommitFormOptions.SigningKeyFormDisplay}}">{{svg "octicon-lock" 24}}</span>
			{{ctx.Locale.Tr "Commit Signed Changes"}}
		{{- else}}
			<span title="{{.CommitFormOptions.WontSignReason}}">{{svg "octicon-unlock" 24}}</span>
			{{ctx.Locale.Tr "Commit Changes"}}
		{{- end}}
		</h3>
		<div class="field">
			<input name="commit_summary" maxlength="100" placeholder="{{if .PageIsDelete}}{{ctx.Locale.Tr "Delete %s" .TreePath}}{{else if .PageIsUpload}}{{ctx.Locale.Tr "Upload files to \"%s\"" .TreePath}}{{else if .IsNewFile}}{{ctx.Locale.Tr "Add '{filename}'"}}{{else if .PageIsPatch}}{{ctx.Locale.Tr "Apply Patch"}}{{else}}{{ctx.Locale.Tr "Update %s" .TreePath}}{{end}}" value="{{.commit_summary}}" autofocus>
		</div>
		<div class="field">
			<textarea name="commit_message" placeholder="{{ctx.Locale.Tr "Add an optional extended description…"}}" rows="5">{{.commit_message}}</textarea>
		</div>
		<div class="inline field">
			<div class="ui checkbox">
				<input name="signoff" type="checkbox">
				<label>{{ctx.Locale.Tr "Add a Signed-off-by trailer by the committer at the end of the commit log message."}}</label>
			</div>
		</div>
		<div class="quick-pull-choice js-quick-pull-choice">
			<div class="field">
				<div class="ui radio checkbox {{if not .CommitFormOptions.CanCommitToBranch}}disabled{{end}}">
					<input type="radio" class="js-quick-pull-choice-option" name="commit_choice" value="direct" data-button-text="{{ctx.Locale.Tr "Commit Changes"}}" {{if eq .commit_choice "direct"}}checked{{end}}>
					<label>
						{{svg "octicon-git-commit"}}
						{{ctx.Locale.Tr "Commit directly to the <strong class=\"branch-name\">%s</strong> branch." .BranchName}}
						{{if not .CommitFormOptions.CanCommitToBranch}}
						<div class="ui visible small warning message">
							{{ctx.Locale.Tr "Unable to commit directly to branch because:"}}
							<ul>
								{{if not .CommitFormOptions.UserCanPush}}<li>{{ctx.Locale.Tr "User cannot push to branch"}}</li>{{end}}
								{{if and .CommitFormOptions.RequireSigned (not .CommitFormOptions.WillSign)}}<li>{{ctx.Locale.Tr "Branch requires a signed commit"}}</li>{{end}}
							</ul>
						</div>
						{{end}}
					</label>
				</div>
			</div>
			{{if and (not .Repository.IsEmpty) (not .IsEditingFileOnly)}}
				<div class="field">
					<div class="ui radio checkbox">
						{{if .CommitFormOptions.CanCreatePullRequest}}
							<input type="radio" class="js-quick-pull-choice-option" name="commit_choice" value="commit-to-new-branch" data-button-text="{{ctx.Locale.Tr "Propose file change"}}" {{if eq .commit_choice "commit-to-new-branch"}}checked{{end}}>
						{{else}}
							<input type="radio" class="js-quick-pull-choice-option" name="commit_choice" value="commit-to-new-branch" data-button-text="{{ctx.Locale.Tr "Commit Changes"}}" {{if eq .commit_choice "commit-to-new-branch"}}checked{{end}}>
						{{end}}
						<label>
							{{svg "octicon-git-pull-request"}}
							{{if .CommitFormOptions.CanCreatePullRequest}}
								{{ctx.Locale.Tr "Create a <strong>new branch</strong> for this commit and start a pull request."}}
							{{else}}
								{{ctx.Locale.Tr "Create a <strong>new branch</strong> for this commit."}}
							{{end}}
						</label>
					</div>
				</div>
				<div class="quick-pull-branch-name {{if not (eq .commit_choice "commit-to-new-branch")}}tw-hidden{{end}}">
					<div class="new-branch-name-input field">
						{{svg "octicon-git-branch"}}
						<input type="text" name="new_branch_name" maxlength="100" value="{{.new_branch_name}}" class="input-contrast tw-mr-1 js-quick-pull-new-branch-name" placeholder="{{ctx.Locale.Tr "New branch name…"}}" {{if eq .commit_choice "commit-to-new-branch"}}required{{end}} title="{{ctx.Locale.Tr "Name the new branch for this commit"}}">
						<span class="text-muted js-quick-pull-normalization-info"></span>
					</div>
				</div>
			{{end}}
		</div>
		{{if and .CommitCandidateEmails (gt (len .CommitCandidateEmails) 1)}}
			<div class="field">
				<label>{{ctx.Locale.Tr "Commit email address"}}</label>
				<select class="ui selection dropdown" name="commit_email">
					{{- range $email := .CommitCandidateEmails -}}
						<option {{if eq $email $.CommitDefaultEmail}}selected{{end}} value="{{$email}}">{{$email}}</option>
					{{- end -}}
				</select>
			</div>
		{{end}}
	</div>
	<input type="hidden" name="last_commit" value="{{.last_commit}}">
	<button id="commit-button" type="submit" class="ui primary button">
		{{if eq .commit_choice "commit-to-new-branch"}}{{ctx.Locale.Tr "Propose file change"}}{{else}}{{ctx.Locale.Tr "Commit Changes"}}{{end}}
	</button>
	<a class="ui button red" href="{{if .ReturnURI}}{{.ReturnURI}}{{else}}{{$.BranchLink}}/{{PathEscapeSegments .TreePath}}{{end}}">{{ctx.Locale.Tr "Cancel"}}</a>
</div>
