<div class="ui small modal" id="issue-label-edit-modal"
		data-current-page-link="{{$.Link}}"{{/*will be used to construct "new label" and "edit label" URLs*/}}
		data-text-new-label="{{ctx.Locale.Tr "New Label"}}"
		data-text-edit-label="{{ctx.Locale.Tr "Edit Label"}}"
>
	<div class="header"></div>
	<div class="content">
		<form class="ui form ignore-dirty form-fetch-action" method="post">
			{{.CsrfTokenHtml}}
			<input name="id" type="hidden">
			<div class="required field">
				<label for="name">{{ctx.Locale.Tr "Name"}}</label>
				<div class="ui small input">
					<input class="label-name-input" name="title" placeholder="{{ctx.Locale.Tr "Label name"}}" autofocus required maxlength="50">
				</div>
			</div>
			<div class="field label-exclusive-input-field">
				<div class="ui checkbox">
					<input class="label-exclusive-input" name="exclusive" type="checkbox">
					<label>{{ctx.Locale.Tr "Exclusive"}}</label>
				</div>
				<br>
				<small class="desc">{{ctx.Locale.Tr "Name the label <code>scope/item</code> to make it mutually exclusive with other <code>scope/</code> labels."}}</small>
				<div class="desc tw-ml-1 tw-mt-2 tw-hidden label-exclusive-warning">
					{{svg "octicon-alert"}} {{ctx.Locale.Tr "Any conflicting scoped labels will be removed when editing the labels of an issue or pull request."}}
				</div>
				<div class="field label-exclusive-order-input-field tw-mt-2">
					<label class="flex-text-block">
						{{ctx.Locale.Tr "Sort Order"}}
						<span data-tooltip-content="{{ctx.Locale.Tr "Exclusive labels in the same scope will be sorted according to this numeric order."}}">{{svg "octicon-info"}}</span>
					</label>
					<input class="label-exclusive-order-input" name="exclusive_order" type="number" maxlength="4">
				</div>
			</div>
			<div class="field label-is-archived-input-field">
				<div class="ui checkbox">
					<input class="label-is-archived-input" name="is_archived" type="checkbox">
					<label>{{ctx.Locale.Tr "Archive Label"}}</label>
				</div>
				<i class="tw-ml-1" data-tooltip-content={{ctx.Locale.Tr "Archived labels are excluded by default from the suggestions when searching by label."}}>
					{{svg "octicon-info"}}
				</i>
			</div>
			<div class="field">
				<label for="description">{{ctx.Locale.Tr "Description"}}</label>
				<div class="ui small fluid input">
					<input class="label-desc-input" name="description" placeholder="{{ctx.Locale.Tr "Description"}}" maxlength="200">
				</div>
			</div>
			<div class="field">
				<label for="color">{{ctx.Locale.Tr "Color"}}</label>
				<div class="color-picker-combo" data-global-init="initColorPicker">
					<!-- the "#" is optional because backend NormalizeColor is able to handle it, API also accepts both formats, and it is easier for users to directly copy-paste a hex value -->
					<input name="color" value="#70c24a" placeholder="#c320f6" required pattern="^#?([\dA-Fa-f]{3}|[\dA-Fa-f]{6})$" maxlength="7">
					{{template "repo/issue/label_precolors"}}
				</div>
			</div>
		</form>
	</div>
	<div class="actions">
		<button class="ui small basic cancel button">
			{{svg "octicon-x"}}
			{{ctx.Locale.Tr "Cancel"}}
		</button>
		<button class="ui primary small approve button">
			{{svg "fontawesome-save"}}
			{{ctx.Locale.Tr "Save"}}
		</button>
	</div>
</div>
