<div class="ui centered grid">
	<div class="twelve wide computer column">
		<p>{{ctx.Locale.Tr "No labels exist yet. Create a label with 'New Label' or use a predefined label set:"}}</p>
		<form class="ui form center" action="{{.Link}}/initialize" method="post">
			{{.CsrfTokenHtml}}
			<div class="field">
				<div class="ui selection dropdown">
					<input type="hidden" name="template_name" value="Default">
					<div class="default text">{{ctx.Locale.Tr "Select a label set"}}</div>
					<div class="menu">
						{{range .LabelTemplateFiles}}
							<div class="item" data-value="{{.DisplayName}}">{{.DisplayName}}<br><i>({{.Description}})</i></div>
						{{end}}
					</div>
					{{svg "octicon-triangle-down" 18 "dropdown icon"}}
				</div>
			</div>
			<button type="submit" class="ui primary button">{{ctx.Locale.Tr "Use Label Set"}}</button>
		</form>
	</div>
</div>
