<div class="ui small modal" id="push-mirror-edit-modal">
	<div class="header">
		{{ctx.Locale.Tr "Edit mirror sync interval"}}
	</div>
	<form class="content ui form ignore-dirty" method="post">
		{{.CsrfTokenHtml}}
		<input type="hidden" name="action" value="push-mirror-update">
		<input type="hidden" name="push_mirror_id" id="push-mirror-edit-id">
		<div class="field">
			<label>{{ctx.Locale.Tr "Mirrored repository"}}</label>
			<span id="push-mirror-edit-address"></span>
		</div>
		<div class="field">
			<label for="push-mirror-edit-interval">{{ctx.Locale.Tr "Mirror Interval (valid time units are 'h', 'm', 's'). 0 to disable periodic sync. (Minimum interval: %s)" .MinimumMirrorInterval}}</label>
			<input id="push-mirror-edit-interval" name="push_mirror_interval" class="tw-w-auto">
		</div>
		<div class="actions">
			<button class="ui small basic cancel button">
				{{svg "octicon-x"}}
				{{ctx.Locale.Tr "Cancel"}}
			</button>
			<button class="ui primary small approve button">
				{{svg "fontawesome-save"}}
				{{ctx.Locale.Tr "Save"}}
			</button>
		</div>
	</form>
</div>
