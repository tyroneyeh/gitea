{{template "repo/settings/layout_head" (dict "ctxData" . "pageClass" "repository settings branches")}}
	<div class="repo-setting-content">
		<form class="ui form" action="{{.Link}}" method="post">
			<h4 class="ui top attached header">
				{{if .Rule.RuleName}}
					{{ctx.Locale.Tr "Branch Protection Rules for Branch '<b>%s</b>'" .Rule.RuleName}}
				{{else}}
					{{ctx.Locale.Tr "Add New Rule"}}
				{{end}}
			</h4>
			<div class="ui attached segment branch-protection">
				<h5 class="ui dividing header">{{ctx.Locale.Tr "Patterns"}}</h5>
				<div class="field required">
					<label>{{ctx.Locale.Tr "Protected Branch Name Pattern"}}</label>
					<input name="rule_name" type="text" value="{{.Rule.RuleName}}" required>
					<input name="rule_id" type="hidden" value="{{.Rule.ID}}">
					<p class="help tw-ml-0">{{ctx.Locale.Tr "Protected branch name patterns. See <a href=\"%s\">the documentation</a> for pattern syntax. Examples: main, release/**" "https://github.com/gobwas/glob"}}</p>
				</div>
				<div class="field">
					<label>{{ctx.Locale.Tr "Protected file patterns (separated using semicolon ';'):"}}</label>
					<input name="protected_file_patterns" type="text" value="{{.Rule.ProtectedFilePatterns}}">
					<p class="help tw-ml-0">{{ctx.Locale.Tr "Protected files are not allowed to be changed directly even if user has rights to add, edit, or delete files in this branch. Multiple patterns can be separated using semicolon (';'). See <a href='%[1]s'>%[2]s</a> documentation for pattern syntax. Examples: <code>.drone.yml</code>, <code>/docs/**/*.txt</code>." "https://pkg.go.dev/github.com/gobwas/glob#Compile" "github.com/gobwas/glob"}}</p>
				</div>
				<div class="field">
					<label>{{ctx.Locale.Tr "Unprotected file patterns (separated using semicolon ';'):"}}</label>
					<input name="unprotected_file_patterns" type="text" value="{{.Rule.UnprotectedFilePatterns}}">
					<p class="help tw-ml-0">{{ctx.Locale.Tr "Unprotected files that are allowed to be changed directly if user has write access, bypassing push restriction. Multiple patterns can be separated using semicolon (';'). See <a href='%[1]s'>%[2]s</a> documentation for pattern syntax. Examples: <code>.drone.yml</code>, <code>/docs/**/*.txt</code>." "https://pkg.go.dev/github.com/gobwas/glob#Compile" "github.com/gobwas/glob"}}</p>
				</div>

				{{.CsrfTokenHtml}}
				<h5 class="ui dividing header">{{ctx.Locale.Tr "Push"}}</h5>
				<div class="field">
					<div class="ui radio checkbox">
						<input name="enable_push" type="radio" value="none" class="toggle-target-disabled" data-target="#whitelist_box" {{if not .Rule.CanPush}}checked{{end}}>
						<label>{{ctx.Locale.Tr "Disable Push"}}</label>
						<p class="help">{{ctx.Locale.Tr "No pushing will be allowed to this branch."}}</p>
					</div>
				</div>
				<div class="field">
					<div class="ui radio checkbox">
						<input name="enable_push" type="radio" value="all" class="toggle-target-disabled" data-target="#whitelist_box" {{if and (.Rule.CanPush) (not .Rule.EnableWhitelist)}}checked{{end}}>
						<label>{{ctx.Locale.Tr "Enable Push"}}</label>
						<p class="help">{{ctx.Locale.Tr "Anyone with write access will be allowed to push to this branch (but not force push)."}}</p>
					</div>
				</div>
				<div class="grouped fields">
					<div class="field">
						<div class="ui radio checkbox">
							<input name="enable_push" type="radio" value="whitelist" class="toggle-target-enabled" data-target="#whitelist_box" {{if and (.Rule.CanPush) (.Rule.EnableWhitelist)}}checked{{end}}>
							<label>{{ctx.Locale.Tr "Allowlist Restricted Push"}}</label>
							<p class="help">{{ctx.Locale.Tr "Only allowlisted users or teams will be allowed to push to this branch (but not force push)."}}</p>
						</div>
					</div>
					<div id="whitelist_box" class="grouped fields {{if not .Rule.EnableWhitelist}}disabled{{end}}">
						<div class="checkbox-sub-item field">
							<label>{{ctx.Locale.Tr "Allowlisted users for pushing:"}}</label>
							<div class="ui multiple search selection dropdown">
								<input type="hidden" name="whitelist_users" value="{{.whitelist_users}}">
								<div class="default text">{{ctx.Locale.Tr "Search users…"}}</div>
								<div class="menu">
									{{range .Users}}
										<div class="item" data-value="{{.ID}}">
											{{ctx.AvatarUtils.Avatar . 28 "mini"}}{{template "repo/search_name" .}}
										</div>
									{{end}}
								</div>
							</div>
						</div>
						{{if .Owner.IsOrganization}}
							<div class="checkbox-sub-item field">
								<label>{{ctx.Locale.Tr "Allowlisted teams for pushing:"}}</label>
								<div class="ui multiple search selection dropdown">
									<input type="hidden" name="whitelist_teams" value="{{.whitelist_teams}}">
									<div class="default text">{{ctx.Locale.Tr "Search teams…"}}</div>
									<div class="menu">
										{{range .Teams}}
											<div class="item" data-value="{{.ID}}">
												{{svg "octicon-people"}}
												{{.Name}}
											</div>
										{{end}}
									</div>
								</div>
							</div>
						{{end}}
						<div class="checkbox-sub-item field">
							<div class="ui checkbox">
								<input type="checkbox" name="whitelist_deploy_keys" {{if .Rule.WhitelistDeployKeys}}checked{{end}}>
								<label>{{ctx.Locale.Tr "Allowlist deploy keys with write access to push."}}</label>
							</div>
						</div>
					</div>
				</div>
				<div class="field">
					<div class="ui checkbox">
						<input name="require_signed_commits" type="checkbox" {{if .Rule.RequireSignedCommits}}checked{{end}}>
						<label>{{ctx.Locale.Tr "Require Signed Commits"}}</label>
						<p class="help">{{ctx.Locale.Tr "Reject pushes to this branch if they are unsigned or unverifiable."}}</p>
					</div>
				</div>
				<h5 class="ui dividing header">{{ctx.Locale.Tr "Force Push"}}</h5>
				<div class="field">
					<div class="ui radio checkbox">
						<input type="radio" name="enable_force_push" value="none" class="toggle-target-disabled" data-target="#force_push_allowlist_box" {{if not .Rule.CanForcePush}}checked{{end}}>
						<label>{{ctx.Locale.Tr "Disable Force Push"}}</label>
						<p class="help">{{ctx.Locale.Tr "No force pushing will be allowed to this branch."}}</p>
					</div>
				</div>
				<div class="field">
					<div class="ui radio checkbox">
						<input type="radio" name="enable_force_push" value="all" class="toggle-target-disabled" data-target="#force_push_allowlist_box" {{if and (.Rule.CanForcePush) (not .Rule.EnableForcePushAllowlist)}}checked{{end}}>
						<label>{{ctx.Locale.Tr "Enable Force Push"}}</label>
						<p class="help">{{ctx.Locale.Tr "Anyone with push access will be allowed to force push to this branch."}}</p>
					</div>
				</div>
				<div class="grouped fields">
					<div class="field">
						<div class="ui radio checkbox">
							<input type="radio" name="enable_force_push" value="whitelist" class="toggle-target-enabled" data-target="#force_push_allowlist_box" {{if and (.Rule.CanForcePush) (.Rule.EnableForcePushAllowlist)}}checked{{end}}>
							<label>{{ctx.Locale.Tr "Allowlist Restricted Force Push"}}</label>
							<p class="help">{{ctx.Locale.Tr "Only allowlisted users or teams with push access will be allowed to force push to this branch."}}</p>
						</div>
					</div>
					<div id="force_push_allowlist_box" class="grouped fields {{if not .Rule.EnableForcePushAllowlist}}disabled{{end}}">
						<div class="checkbox-sub-item field">
							<label>{{ctx.Locale.Tr "Allowlisted users for force pushing:"}}</label>
							<div class="ui multiple search selection dropdown">
								<input type="hidden" name="force_push_allowlist_users" value="{{.force_push_allowlist_users}}">
								<div class="default text">{{ctx.Locale.Tr "Search users…"}}</div>
								<div class="menu">
									{{range .Users}}
										<div class="item" data-value="{{.ID}}">
											{{ctx.AvatarUtils.Avatar . 28 "mini"}}{{template "repo/search_name" .}}
										</div>
									{{end}}
								</div>
							</div>
						</div>
						{{if .Owner.IsOrganization}}
							<div class="checkbox-sub-item field">
								<label>{{ctx.Locale.Tr "Allowlisted teams for force pushing:"}}</label>
								<div class="ui multiple search selection dropdown">
									<input type="hidden" name="force_push_allowlist_teams" value="{{.force_push_allowlist_teams}}">
									<div class="default text">{{ctx.Locale.Tr "Search teams…"}}</div>
									<div class="menu">
										{{range .Teams}}
											<div class="item" data-value="{{.ID}}">
												{{svg "octicon-people"}}
												{{.Name}}
											</div>
										{{end}}
									</div>
								</div>
							</div>
						{{end}}
						<div class="checkbox-sub-item field">
							<div class="ui checkbox">
								<input type="checkbox" name="force_push_allowlist_deploy_keys" {{if .Rule.ForcePushAllowlistDeployKeys}}checked{{end}}>
								<label>{{ctx.Locale.Tr "Allowlist deploy keys with push access to force push."}}</label>
							</div>
						</div>
					</div>
				</div>
				<h5 class="ui dividing header">{{ctx.Locale.Tr "Pull Request Approvals"}}</h5>
				<div class="field">
					<label>{{ctx.Locale.Tr "Required approvals:"}}</label>
					<input name="required_approvals" type="number" value="{{.Rule.RequiredApprovals}}">
					<p class="help tw-ml-0">{{ctx.Locale.Tr "Allow only to merge pull request with enough required approvals. Required approvals are either from users or teams who are on the allowlist or anyone with write access."}}</p>
				</div>
				<div class="grouped fields">
					<div class="field">
						<div class="ui checkbox">
							<input name="enable_approvals_whitelist" type="checkbox" class="toggle-target-enabled" data-target="#approvals_whitelist_box" {{if .Rule.EnableApprovalsWhitelist}}checked{{end}}>
							<label>{{ctx.Locale.Tr "Restrict approvals to allowlisted users or teams"}}</label>
							<p class="help">{{ctx.Locale.Tr "Only reviews from allowlisted users or teams will count to the required approvals. Without approval allowlist, reviews from anyone with write access count to the required approvals."}}</p>
						</div>
					</div>
					<div id="approvals_whitelist_box" class="grouped fields {{if not .Rule.EnableApprovalsWhitelist}}disabled{{end}}">
						<div class="checkbox-sub-item field">
							<label>{{ctx.Locale.Tr "Allowlisted reviewers:"}}</label>
							<div class="ui multiple search selection dropdown">
								<input type="hidden" name="approvals_whitelist_users" value="{{.approvals_whitelist_users}}">
								<div class="default text">{{ctx.Locale.Tr "Search users…"}}</div>
								<div class="menu">
								{{range .Users}}
									<div class="item" data-value="{{.ID}}">
										{{ctx.AvatarUtils.Avatar . 28 "mini"}}{{template "repo/search_name" .}}
									</div>
								{{end}}
								</div>
							</div>
						</div>
						{{if .Owner.IsOrganization}}
							<div class="checkbox-sub-item field">
								<label>{{ctx.Locale.Tr "Allowlisted teams for reviews:"}}</label>
								<div class="ui multiple search selection dropdown">
									<input type="hidden" name="approvals_whitelist_teams" value="{{.approvals_whitelist_teams}}">
									<div class="default text">{{ctx.Locale.Tr "Search teams…"}}</div>
									<div class="menu">
									{{range .Teams}}
										<div class="item" data-value="{{.ID}}">
											{{svg "octicon-people"}}
										{{.Name}}
										</div>
									{{end}}
									</div>
								</div>
							</div>
						{{end}}
					</div>
				</div>
				<div class="field">
					<div class="ui checkbox">
						<input id="dismiss_stale_approvals" name="dismiss_stale_approvals" type="checkbox" {{if .Rule.DismissStaleApprovals}}checked{{end}}>
						<label>{{ctx.Locale.Tr "Dismiss stale approvals"}}</label>
						<p class="help">{{ctx.Locale.Tr "When new commits that change the content of the pull request are pushed to the branch, old approvals will be dismissed."}}</p>
					</div>
				</div>
				<div id="ignore_stale_approvals_box" class="field {{if .Rule.DismissStaleApprovals}}disabled{{end}}">
					<div class="ui checkbox">
						<input id="ignore_stale_approvals" name="ignore_stale_approvals" type="checkbox" {{if .Rule.IgnoreStaleApprovals}}checked{{end}}>
						<label>{{ctx.Locale.Tr "Ignore stale approvals"}}</label>
						<p class="help">{{ctx.Locale.Tr "Do not count approvals that were made on older commits (stale reviews) towards how many approvals the PR has. Irrelevant if stale reviews are already dismissed."}}</p>
					</div>
				</div>
				<div class="grouped fields">
					<div class="field">
						<div class="ui checkbox">
							<input name="enable_status_check" type="checkbox" class="toggle-target-enabled" data-target="#statuscheck_contexts_box" {{if .Rule.EnableStatusCheck}}checked{{end}}>
							<label>{{ctx.Locale.Tr "Enable Status Check"}}</label>
							<p class="help">{{ctx.Locale.Tr "Require status checks to pass before merging. When enabled, commits must first be pushed to another branch, then merged or pushed directly to a branch that matches this rule after status checks have passed. If no contexts are matched, the last commit must be successful regardless of context."}}</p>
						</div>
					</div>
					<div id="statuscheck_contexts_box" class="checkbox-sub-item field {{if not .Rule.EnableStatusCheck}}disabled{{end}}">
						<label>{{ctx.Locale.Tr "Status check patterns:"}}</label>
						<textarea id="status_check_contexts" name="status_check_contexts" rows="3">{{.status_check_contexts}}</textarea>
						<p class="help">{{ctx.Locale.Tr "Enter patterns to specify which status checks must pass before branches can be merged into a branch that matches this rule. Each line specifies a pattern. Patterns cannot be empty."}}</p>
						<table class="ui celled table">
							<thead>
								<tr>
									<th>{{ctx.Locale.Tr "Status checks found in the last week for this repository"}}</th>
								</tr>
							</thead>
							<tbody>
							{{range $.recent_status_checks}}
								<tr>
									<td>
										<span>{{.}}</span>
										<span class="status-check-matched-mark tw-hidden" data-status-check="{{.}}">{{ctx.Locale.Tr "Matched"}}</span>
									</td>
								</tr>
							{{else}}
								<tr><td>-</td></tr>
							{{end}}
							</tbody>
						</table>
					</div>
				</div>
				<h5 class="ui dividing header">{{ctx.Locale.Tr "Pull Request Merge"}}</h5>
				<div class="grouped fields">
					<div class="field">
						<div class="ui radio checkbox">
							<input name="enable_merge_whitelist" type="radio" value="false" class="toggle-target-disabled" data-target="#merge_whitelist_box" {{if not .Rule.EnableMergeWhitelist}}checked{{end}}>
							<label>{{ctx.Locale.Tr "Enable Merge"}}</label>
							<p class="help">{{ctx.Locale.Tr "Anyone with write access will be allowed to merge the pull requests into this branch."}}</p>
						</div>
					</div>
					<div class="field">
						<div class="ui radio checkbox">
							<input name="enable_merge_whitelist" type="radio" value="true" class="toggle-target-enabled" data-target="#merge_whitelist_box" {{if .Rule.EnableMergeWhitelist}}checked{{end}}>
							<label>{{ctx.Locale.Tr "Enable Merge Allowlist"}}</label>
							<p class="help">{{ctx.Locale.Tr "Allow only allowlisted users or teams to merge pull requests into this branch."}}</p>
						</div>
					</div>
					<div id="merge_whitelist_box" class="grouped fields {{if not .Rule.EnableMergeWhitelist}}disabled{{end}}">
						<div class="checkbox-sub-item field">
							<label>{{ctx.Locale.Tr "Allowlisted users for merging:"}}</label>
							<div class="ui multiple search selection dropdown">
								<input type="hidden" name="merge_whitelist_users" value="{{.merge_whitelist_users}}">
								<div class="default text">{{ctx.Locale.Tr "Search users…"}}</div>
								<div class="menu">
								{{range .Users}}
									<div class="item" data-value="{{.ID}}">
										{{ctx.AvatarUtils.Avatar . 28 "mini"}}{{template "repo/search_name" .}}
									</div>
								{{end}}
								</div>
							</div>
						</div>
					{{if .Owner.IsOrganization}}
						<div class="checkbox-sub-item field">
							<label>{{ctx.Locale.Tr "Allowlisted teams for merging:"}}</label>
							<div class="ui multiple search selection dropdown">
								<input type="hidden" name="merge_whitelist_teams" value="{{.merge_whitelist_teams}}">
								<div class="default text">{{ctx.Locale.Tr "Search teams…"}}</div>
								<div class="menu">
								{{range .Teams}}
									<div class="item" data-value="{{.ID}}">
										{{svg "octicon-people"}}
									{{.Name}}
									</div>
								{{end}}
								</div>
							</div>
						</div>
					{{end}}
					</div>
				</div>
				<div class="field">
					<div class="ui checkbox">
						<input name="block_on_rejected_reviews" type="checkbox" {{if .Rule.BlockOnRejectedReviews}}checked{{end}}>
						<label>{{ctx.Locale.Tr "Block merge on rejected reviews"}}</label>
						<p class="help">{{ctx.Locale.Tr "Merging will not be possible when changes are requested by official reviewers, even if there are enough approvals."}}</p>
					</div>
				</div>
				<div class="field">
					<div class="ui checkbox">
						<input name="block_on_official_review_requests" type="checkbox" {{if .Rule.BlockOnOfficialReviewRequests}}checked{{end}}>
						<label>{{ctx.Locale.Tr "Block merge on official review requests"}}</label>
						<p class="help">{{ctx.Locale.Tr "Merging will not be possible when it has official review requests, even if there are enough approvals."}}</p>
					</div>
				</div>
				<div class="field">
					<div class="ui checkbox">
						<input name="block_on_outdated_branch" type="checkbox" {{if .Rule.BlockOnOutdatedBranch}}checked{{end}}>
						<label>{{ctx.Locale.Tr "Block merge if pull request is outdated"}}</label>
						<p class="help">{{ctx.Locale.Tr "Merging will not be possible when head branch is behind base branch."}}</p>
					</div>
				</div>
				<div class="field">
					<div class="ui checkbox">
						<input name="block_admin_merge_override" type="checkbox" {{if .Rule.BlockAdminMergeOverride}}checked{{end}}>
						<label>{{ctx.Locale.Tr "Administrators must follow branch protection rules"}}</label>
						<p class="help">{{ctx.Locale.Tr "Administrators must follow branch protection rules and cannot circumvent it."}}</p>
					</div>
				</div>
				<div class="divider"></div>

				<div class="field">
					<button class="ui primary button">{{ctx.Locale.Tr "Save Rule"}}</button>
				</div>
			</div>
		</form>
	</div>
{{template "repo/settings/layout_footer" .}}
