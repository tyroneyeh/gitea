							{{end}}
							{{if (eq $projectsUnit.ProjectsConfig.GetProjectsMode "owner")}}
								{{ctx.Locale.Tr "Only user or org projects"}}
							{{end}}
							{{if (eq $projectsUnit.ProjectsConfig.GetProjectsMode "all")}}
								{{ctx.Locale.Tr "All projects"}}
							{{end}}
						</div>
						<div class="menu">
							<div class="item" data-value="repo">{{ctx.Locale.Tr "Repo projects only"}}</div>
							<div class="item" data-value="owner">{{ctx.Locale.Tr "Only user or org projects"}}</div>
							<div class="item" data-value="all">{{ctx.Locale.Tr "All projects"}}</div>
						</div>
					</div>
				</div>

				<div class="divider"></div>

				{{$isReleasesEnabled := .Repository.UnitEnabled ctx ctx.Consts.RepoUnitTypeReleases}}
				{{$isReleasesGlobalDisabled := ctx.Consts.RepoUnitTypeReleases.UnitGlobalDisabled}}
				<div class="inline field">
					<label>{{ctx.Locale.Tr "Releases"}}</label>
					<div class="ui checkbox{{if $isReleasesGlobalDisabled}} disabled{{end}}"{{if $isReleasesGlobalDisabled}} data-tooltip-content="{{ctx.Locale.Tr "The site administrator has disabled this repository section."}}"{{end}}>
						<input class="enable-system" name="enable_releases" type="checkbox" {{if $isReleasesEnabled}}checked{{end}}>
						<label>{{ctx.Locale.Tr "Enable Repository Releases"}}</label>
					</div>
				</div>

				{{$isPackagesEnabled := .Repository.UnitEnabled ctx ctx.Consts.RepoUnitTypePackages}}
				{{$isPackagesGlobalDisabled := ctx.Consts.RepoUnitTypePackages.UnitGlobalDisabled}}
				<div class="inline field">
					<label>{{ctx.Locale.Tr "Packages"}}</label>
					<div class="ui checkbox{{if $isPackagesGlobalDisabled}} disabled{{end}}"{{if $isPackagesGlobalDisabled}} data-tooltip-content="{{ctx.Locale.Tr "The site administrator has disabled this repository section."}}"{{end}}>
						<input class="enable-system" name="enable_packages" type="checkbox" {{if $isPackagesEnabled}}checked{{end}}>
						<label>{{ctx.Locale.Tr "Enable Repository Packages Registry"}}</label>
					</div>
				</div>

				{{if not .IsMirror}}
					<div class="divider"></div>
					{{$pullRequestEnabled := .Repository.UnitEnabled ctx ctx.Consts.RepoUnitTypePullRequests}}
					{{$pullRequestGlobalDisabled := ctx.Consts.RepoUnitTypePullRequests.UnitGlobalDisabled}}
					{{$prUnit := .Repository.MustGetUnit ctx ctx.Consts.RepoUnitTypePullRequests}}
					<div class="inline field">
						<label>{{ctx.Locale.Tr "Pull Requests"}}</label>
						<div class="ui checkbox{{if $pullRequestGlobalDisabled}} disabled{{end}}"{{if $pullRequestGlobalDisabled}} data-tooltip-content="{{ctx.Locale.Tr "The site administrator has disabled this repository section."}}"{{end}}>
							<input class="enable-system" name="enable_pulls" type="checkbox" data-target="#pull_box" {{if $pullRequestEnabled}}checked{{end}}>
							<label>{{ctx.Locale.Tr "Enable Repository Pull Requests"}}</label>
						</div>
					</div>
					<div class="field{{if not $pullRequestEnabled}} disabled{{end}}" id="pull_box">
						<div class="field">
							<p>
								{{ctx.Locale.Tr "Merge Styles"}}
							</p>
						</div>
						<div class="field">
							<div class="ui checkbox">
								<input name="pulls_allow_merge" type="checkbox" {{if or (not $pullRequestEnabled) ($prUnit.PullRequestsConfig.AllowMerge)}}checked{{end}}>
								<label>{{ctx.Locale.Tr "Create merge commit"}}</label>
							</div>
						</div>
						<div class="field">
							<div class="ui checkbox">
								<input name="pulls_allow_rebase" type="checkbox" {{if or (not $pullRequestEnabled) ($prUnit.PullRequestsConfig.AllowRebase)}}checked{{end}}>
								<label>{{ctx.Locale.Tr "Rebase, then fast-forward"}}</label>
							</div>
						</div>
						<div class="field">
							<div class="ui checkbox">
								<input name="pulls_allow_rebase_merge" type="checkbox" {{if or (not $pullRequestEnabled) ($prUnit.PullRequestsConfig.AllowRebaseMerge)}}checked{{end}}>
								<label>{{ctx.Locale.Tr "Rebase, then create merge commit"}}</label>
							</div>
						</div>
						<div class="field">
							<div class="ui checkbox">
								<input name="pulls_allow_squash" type="checkbox" {{if or (not $pullRequestEnabled) ($prUnit.PullRequestsConfig.AllowSquash)}}checked{{end}}>
								<label>{{ctx.Locale.Tr "Create squash commit"}}</label>
							</div>
						</div>
						<div class="field">
							<div class="ui checkbox">
								<input name="pulls_allow_fast_forward_only" type="checkbox" {{if or (not $pullRequestEnabled) ($prUnit.PullRequestsConfig.AllowFastForwardOnly)}}checked{{end}}>
								<label>{{ctx.Locale.Tr "Fast-forward only"}}</label>
							</div>
						</div>
						<div class="field">
							<div class="ui checkbox">
								<input name="pulls_allow_manual_merge" type="checkbox" {{if or (not $pullRequestEnabled) ($prUnit.PullRequestsConfig.AllowManualMerge)}}checked{{end}}>
								<label>{{ctx.Locale.Tr "Manually merged"}}</label>
							</div>
						</div>

						<div class="field">
							<p>
								{{ctx.Locale.Tr "Default Merge Style"}}
							</p>
							<div class="ui dropdown selection">
								<select name="pulls_default_merge_style">
									<option value="merge" {{if or (not $pullRequestEnabled) (eq $prUnit.PullRequestsConfig.DefaultMergeStyle "merge")}}selected{{end}}>{{ctx.Locale.Tr "Create merge commit"}}</option>
									<option value="rebase" {{if or (not $pullRequestEnabled) (eq $prUnit.PullRequestsConfig.DefaultMergeStyle "rebase")}}selected{{end}}>{{ctx.Locale.Tr "Rebase, then fast-forward"}}</option>
									<option value="rebase-merge" {{if or (not $pullRequestEnabled) (eq $prUnit.PullRequestsConfig.DefaultMergeStyle "rebase-merge")}}selected{{end}}>{{ctx.Locale.Tr "Rebase, then create merge commit"}}</option>
									<option value="squash" {{if or (not $pullRequestEnabled) (eq $prUnit.PullRequestsConfig.DefaultMergeStyle "squash")}}selected{{end}}>{{ctx.Locale.Tr "Create squash commit"}}</option>
									<option value="fast-forward-only" {{if or (not $pullRequestEnabled) (eq $prUnit.PullRequestsConfig.DefaultMergeStyle "fast-forward-only")}}selected{{end}}>{{ctx.Locale.Tr "Fast-forward only"}}</option>
								</select>{{svg "octicon-triangle-down" 14 "dropdown icon"}}
								<div class="default text">
									{{if (eq $prUnit.PullRequestsConfig.DefaultMergeStyle "merge")}}
										{{ctx.Locale.Tr "Create merge commit"}}
									{{end}}
									{{if (eq $prUnit.PullRequestsConfig.DefaultMergeStyle "rebase")}}
										{{ctx.Locale.Tr "Rebase, then fast-forward"}}
									{{end}}
									{{if (eq $prUnit.PullRequestsConfig.DefaultMergeStyle "rebase-merge")}}
										{{ctx.Locale.Tr "Rebase, then create merge commit"}}
									{{end}}
									{{if (eq $prUnit.PullRequestsConfig.DefaultMergeStyle "squash")}}
										{{ctx.Locale.Tr "Create squash commit"}}
									{{end}}
									{{if (eq $prUnit.PullRequestsConfig.DefaultMergeStyle "fast-forward-only")}}
										{{ctx.Locale.Tr "Fast-forward only"}}
									{{end}}
								</div>
								<div class="menu">
									<div class="item" data-value="merge">{{ctx.Locale.Tr "Create merge commit"}}</div>
									<div class="item" data-value="rebase">{{ctx.Locale.Tr "Rebase, then fast-forward"}}</div>
									<div class="item" data-value="rebase-merge">{{ctx.Locale.Tr "Rebase, then create merge commit"}}</div>
									<div class="item" data-value="squash">{{ctx.Locale.Tr "Create squash commit"}}</div>
									<div class="item" data-value="fast-forward-only">{{ctx.Locale.Tr "Fast-forward only"}}</div>
								</div>
							</div>
						</div>
						<div class="field">
							<div class="ui checkbox">
								<input name="default_allow_maintainer_edit" type="checkbox" {{if or (not $pullRequestEnabled) ($prUnit.PullRequestsConfig.DefaultAllowMaintainerEdit)}}checked{{end}}>
								<label>{{ctx.Locale.Tr "Allow edits from maintainers by default"}}</label>
							</div>
						</div>
						<div class="field">
							<div class="ui checkbox">
								<input name="pulls_allow_rebase_update" type="checkbox" {{if or (not $pullRequestEnabled) ($prUnit.PullRequestsConfig.AllowRebaseUpdate)}}checked{{end}}>
								<label>{{ctx.Locale.Tr "Enable updating pull request branch by rebase"}}</label>
							</div>
						</div>
						<div class="field">
							<div class="ui checkbox">
								<input name="default_delete_branch_after_merge" type="checkbox" {{if or (not $pullRequestEnabled) ($prUnit.PullRequestsConfig.DefaultDeleteBranchAfterMerge)}}checked{{end}}>
								<label>{{ctx.Locale.Tr "Delete pull request branch after merge by default"}}</label>
							</div>
						</div>
						<div class="field">
							<div class="ui checkbox">
								<input name="enable_autodetect_manual_merge" type="checkbox" {{if or (not $pullRequestEnabled) ($prUnit.PullRequestsConfig.AutodetectManualMerge)}}checked{{end}}>
								<label>{{ctx.Locale.Tr "Enable autodetect manual merge (Note: In some special cases, misjudgments can occur)"}}</label>
							</div>
						</div>
						<div class="field">
							<div class="ui checkbox">
								<input name="pulls_ignore_whitespace" type="checkbox" {{if and $pullRequestEnabled ($prUnit.PullRequestsConfig.IgnoreWhitespaceConflicts)}}checked{{end}}>
								<label>{{ctx.Locale.Tr "Ignore Whitespace for Conflicts"}}</label>
							</div>
						</div>
					</div>
				{{end}}

				<div class="divider"></div>
				<div class="field">
					<button class="ui primary button">{{ctx.Locale.Tr "Update Settings"}}</button>
				</div>
			</form>
		</div>

		<h4 class="ui top attached header">
			{{ctx.Locale.Tr "Signing Verification Settings"}}
		</h4>
		<div class="ui attached segment">
			<form class="ui form" method="post">
				{{.CsrfTokenHtml}}
				<input type="hidden" name="action" value="signing">
				<div class="field">
					<label>{{ctx.Locale.Tr "Signature Trust Model"}}</label><br>
					<div class="field">
						<div class="ui radio checkbox">
							<input type="radio" id="trust_model_default" name="trust_model" {{if eq .Repository.TrustModel.String "default"}}checked="checked"{{end}} value="default">
							<label for="trust_model_default">{{ctx.Locale.Tr "Default Trust Model"}}</label>
							<p class="help">{{ctx.Locale.Tr "Use the default repository trust model for this installation."}}</p>
						</div>
					</div>
					<div class="field">
						<div class="ui radio checkbox">
							<input type="radio" id="trust_model_collaborator" name="trust_model" {{if eq .Repository.TrustModel.String "collaborator"}}checked="checked"{{end}} value="collaborator">
							<label for="trust_model_collaborator">{{ctx.Locale.Tr "Collaborator: Trust signatures by collaborators"}}</label>
							<p class="help">{{ctx.Locale.Tr "Valid signatures by collaborators of this repository will be marked \"trusted\", whether they match the committer or not. Otherwise, valid signatures will be marked \"untrusted\" if the signature matches the committer and \"unmatched\" if not."}}</p>
						</div>
					</div>
					<div class="field">
						<div class="ui radio checkbox">
							<input type="radio" name="trust_model" id="trust_model_committer" {{if eq .Repository.TrustModel.String "committer"}}checked="checked"{{end}} value="committer">
							<label for="trust_model_committer">{{ctx.Locale.Tr "Committer: Trust signatures that match committers. This matches GitHub's behavior and will force commits signed by Gitea to have Gitea as the committer."}}</label>
							<p class="help">{{ctx.Locale.Tr "Valid signatures will only be marked \"trusted\" if they match the committer, otherwise they will be marked \"unmatched\". This forces Gitea to be the committer on signed commits, with the actual committer marked as Co-authored-by: and Co-committed-by: trailer in the commit. The default Gitea key must match a user in the database."}}</p>
						</div>
					</div>
					<div class="field">
						<div class="ui radio checkbox">
							<input type="radio" name="trust_model" id="trust_model_collaboratorcommitter" {{if eq .Repository.TrustModel.String "collaboratorcommitter"}}checked="checked"{{end}} value="collaboratorcommitter">
							<label for="trust_model_collaboratorcommitter">{{ctx.Locale.Tr "Collaborator+Committer: Trust signatures by collaborators which match the committer"}}</label>
							<p class="help">{{ctx.Locale.Tr "Valid signatures by collaborators of this repository will be marked \"trusted\" if they match the committer. Otherwise, valid signatures will be marked \"untrusted\" if the signature matches the committer and \"unmatched\" otherwise. This will force Gitea to be marked as the committer on signed commits, with the actual committer marked as Co-Authored-By: and Co-Committed-By: trailer in the commit. The default Gitea key must match a user in the database."}}</p>
						</div>
					</div>
				</div>

				<div class="divider"></div>
				<div class="field">
					<button class="ui primary button">{{ctx.Locale.Tr "Update Settings"}}</button>
				</div>
			</form>
		</div>

		{{if .IsAdmin}}
		<h4 class="ui top attached header">
			{{ctx.Locale.Tr "Administrator Settings"}}
		</h4>
		<div class="ui attached segment">
			<form class="ui form" method="post">
				{{.CsrfTokenHtml}}
				<input type="hidden" name="action" value="admin">
				<div class="field">
					<div class="ui checkbox">
						<input name="enable_health_check" type="checkbox" {{if .Repository.IsFsckEnabled}}checked{{end}}>
						<label>{{ctx.Locale.Tr "Enable Repository Health Checks (git fsck)"}}</label>
					</div>
				</div>

				<div class="field">
					<button class="ui primary button">{{ctx.Locale.Tr "Update Settings"}}</button>
				</div>
			</form>

			<div class="divider"></div>
			<form class="ui form" method="post">
				{{.CsrfTokenHtml}}
				<input type="hidden" name="action" value="admin_index">
				{{if .IsRepoIndexerEnabled}}
					<h4 class="ui header">{{ctx.Locale.Tr "Code Indexer"}}</h4>
					<div class="inline fields">
						<label>{{ctx.Locale.Tr "Last Indexed SHA"}}</label>
						<span class="field">
							{{if .CodeIndexerStatus}}
								<a rel="nofollow" class="ui sha label" href="{{.RepoLink}}/commit/{{.CodeIndexerStatus.CommitSha}}">
									{{ShortSha .CodeIndexerStatus.CommitSha}}
								</a>
							{{else}}
									<span>{{ctx.Locale.Tr "Unindexed"}}</span>
							{{end}}
						</span>
						<div class="field">
							<button class="ui primary button" name="request_reindex_type" value="code">{{ctx.Locale.Tr "Add to Reindex Queue"}}</button>
						</div>
					</div>
				{{end}}
				<h4 class="ui header">{{ctx.Locale.Tr "Code Statistics Indexer"}}</h4>
				<div class="inline fields">
					{{if and .StatsIndexerStatus .StatsIndexerStatus.CommitSha}}
						<label>{{ctx.Locale.Tr "Last Indexed SHA"}}</label>
					{{end}}
					<span class="field">
						{{if and .StatsIndexerStatus .StatsIndexerStatus.CommitSha}}
							<a rel="nofollow" class="ui sha label" href="{{.RepoLink}}/commit/{{.StatsIndexerStatus.CommitSha}}">
								{{ShortSha .StatsIndexerStatus.CommitSha}}
							</a>
						{{else}}
							<span>{{ctx.Locale.Tr "Unindexed"}}</span>
						{{end}}
					</span>
					<div class="field">
						<button class="ui primary button" name="request_reindex_type" value="stats">{{ctx.Locale.Tr "Add to Reindex Queue"}}</button>
					</div>
				</div>
			</form>
		</div>
		{{end}}

		{{if .Permission.IsOwner}}
		<h4 class="ui top attached error header">
			{{ctx.Locale.Tr "Danger Zone"}}
		</h4>
		<div class="ui attached error danger segment">
			<div class="flex-list">
				{{if not .Repository.IsFork}}
					<div class="flex-item tw-items-center">
						<div class="flex-item-main">
							<div class="flex-item-title">{{ctx.Locale.Tr "Visibility"}}</div>
							{{if .Repository.IsPrivate}}
								<div class="flex-item-body">{{ctx.Locale.Tr "Changing the visibility to public will make the repo visible to anyone."}}</div>
							{{else}}
								<div class="flex-item-body">{{ctx.Locale.Tr "Changing the visibility to private will make the repo visible only to allowed members and may remove the relationship between it and existing forks, watchers, and stars."}}</div>
							{{end}}
						</div>
						<div class="flex-item-trailing">
							<button class="ui basic red show-modal button" data-modal="#visibility-repo-modal">
								{{if .Repository.IsPrivate}}
									{{ctx.Locale.Tr "Make Public"}}
								{{else}}
									{{ctx.Locale.Tr "Make Private"}}
								{{end}}
							</button>
						</div>
					</div>
				{{end}}
				{{if .Repository.IsMirror}}
					<div class="flex-item">
						<div class="flex-item-main">
							<div class="flex-item-title">{{ctx.Locale.Tr "Convert to Regular Repository"}}</div>
							<div class="flex-item-body">{{ctx.Locale.Tr "You can convert this mirror into a regular repository. This cannot be undone."}}</div>
						</div>
						<div class="flex-item-trailing">
							<button class="ui basic red show-modal button" data-modal="#convert-mirror-repo-modal">{{ctx.Locale.Tr "Convert to Regular Repository"}}</button>
						</div>
					</div>
				{{end}}
				{{if .CanConvertFork}}
					<div class="flex-item">
						<div class="flex-item-main">
							<div class="flex-item-title">{{ctx.Locale.Tr "Convert to Regular Repository"}}</div>
							<div class="flex-item-body">{{ctx.Locale.Tr "You can convert this fork into a regular repository. This cannot be undone."}}</div>
						</div>
						<div class="flex-item-trailing">
							<button class="ui basic red show-modal button" data-modal="#convert-fork-repo-modal">{{ctx.Locale.Tr "Convert to Regular Repository"}}</button>
						</div>
					</div>
				{{end}}
				<div class="flex-item">
					<div class="flex-item-main">
						<div class="flex-item-title">{{ctx.Locale.Tr "Transfer Ownership"}}</div>
						<div class="flex-item-body">
							{{if .RepoTransfer}}
								{{ctx.Locale.Tr "This repository has been marked for transfer and awaits confirmation from \"%s\"" .RepoTransfer.Recipient.DisplayName}}
							{{else}}
								{{ctx.Locale.Tr "Transfer this repository to a user or to an organization for which you have administrator rights."}}
							{{end}}
						</div>
					</div>
					<div class="flex-item-trailing">
						{{if .RepoTransfer}}
							<form class="ui form" action="{{.Link}}" method="post">
								{{.CsrfTokenHtml}}
								<input type="hidden" name="action" value="cancel_transfer">
								<button class="ui red button">{{ctx.Locale.Tr "Cancel transfer"}}</button>
							</form>
						{{else}}
							<button class="ui basic red show-modal button" data-modal="#transfer-repo-modal">{{ctx.Locale.Tr "Transfer Ownership"}}</button>
						{{end}}
					</div>
				</div>
				{{if .Permission.CanRead ctx.Consts.RepoUnitTypeWiki}}
					<div class="flex-item">
						<div class="flex-item-main">
							<div class="flex-item-title">{{ctx.Locale.Tr "Delete Wiki Data"}}</div>
							<div class="flex-item-body">{{ctx.Locale.Tr "Deleting repository wiki data is permanent and cannot be undone."}}</div>
						</div>
						<div class="flex-item-trailing">
							<button class="ui basic red show-modal button" data-modal="#delete-wiki-modal">{{ctx.Locale.Tr "Delete Wiki Data"}}</button>
						</div>
					</div>
				{{end}}
				<div class="flex-item">
					<div class="flex-item-main">
						<div class="flex-item-title">{{ctx.Locale.Tr "Delete This Repository"}}</div>
						<div class="flex-item-body">{{ctx.Locale.Tr "Deleting a repository is permanent and cannot be undone."}}</div>
					</div>
					<div class="flex-item-trailing">
						<button class="ui basic red show-modal button" data-modal="#delete-repo-modal">{{ctx.Locale.Tr "Delete This Repository"}}</button>
					</div>
				</div>
				{{if not .Repository.IsMirror}}
					<div class="flex-item tw-items-center">
						<div class="flex-item-main">
							{{if .Repository.IsArchived}}
								<div class="flex-item-title">{{ctx.Locale.Tr "Unarchive this repo"}}</div>
								<div class="flex-item-body">{{ctx.Locale.Tr "Unarchiving the repo will restore its ability to receive commits and pushes, as well as new issues and pull requests."}}</div>
							{{else}}
								<div class="flex-item-title">{{ctx.Locale.Tr "Archive This Repo"}}</div>
								<div class="flex-item-body">{{ctx.Locale.Tr "Archiving the repo will make it entirely read-only. It will be hidden from the dashboard. Nobody (not even you!) will be able to make new commits, or open any issues or pull requests."}}</div>
							{{end}}
						</div>
						<div class="flex-item-trailing">
							<button class="ui basic red show-modal button" data-modal="#archive-repo-modal">
								{{if .Repository.IsArchived}}
									{{ctx.Locale.Tr "Unarchive repo"}}
								{{else}}
									{{ctx.Locale.Tr "Archive Repo"}}
								{{end}}
							</button>
						</div>
					</div>
				{{end}}
			</div>
		</div>
		{{end}}
	</div>
{{template "repo/settings/layout_footer" .}}

{{if .Permission.IsOwner}}
	{{if .Repository.IsMirror}}
		<div class="ui small modal" id="convert-mirror-repo-modal">
			<div class="header">
				{{ctx.Locale.Tr "Convert to Regular Repository"}}
			</div>
			<div class="content">
				<div class="ui warning message">
					{{ctx.Locale.Tr "This operation will convert the mirror into a regular repository and cannot be undone."}}
				</div>
				<form class="ui form" action="{{.Link}}" method="post">
					{{.CsrfTokenHtml}}
					<input type="hidden" name="action" value="convert">
					<div class="field">
						<label>
							{{ctx.Locale.Tr "Enter the repository name as confirmation:"}}
							<span class="text red">{{.Repository.Name}}</span>
						</label>
					</div>
					<div class="required field">
						<label>{{ctx.Locale.Tr "Repository Name"}}</label>
						<input name="repo_name" required maxlength="100">
					</div>

					<div class="actions">
						<button class="ui cancel button">{{ctx.Locale.Tr "Cancel"}}</button>
						<button class="ui red button">{{ctx.Locale.Tr "Convert Repository"}}</button>
					</div>
				</form>
			</div>
		</div>
	{{end}}
	{{if .CanConvertFork}}
		<div class="ui small modal" id="convert-fork-repo-modal">
			<div class="header">
				{{ctx.Locale.Tr "Convert to Regular Repository"}}
			</div>
			<div class="content">
				<div class="ui warning message">
					{{ctx.Locale.Tr "This operation will convert the fork into a regular repository and cannot be undone."}}
				</div>
				<form class="ui form" action="{{.Link}}" method="post">
					{{.CsrfTokenHtml}}
					<input type="hidden" name="action" value="convert_fork">
					<div class="field">
						<label>
							{{ctx.Locale.Tr "Enter the repository name as confirmation:"}}
							<span class="text red">{{.Repository.Name}}</span>
						</label>
					</div>
					<div class="required field">
						<label>{{ctx.Locale.Tr "Repository Name"}}</label>
						<input name="repo_name" required>
					</div>

					<div class="actions">
						<button class="ui cancel button">{{ctx.Locale.Tr "Cancel"}}</button>
						<button class="ui red button">{{ctx.Locale.Tr "Convert Repository"}}</button>
					</div>
				</form>
			</div>
		</div>
	{{end}}
	<div class="ui small modal" id="transfer-repo-modal">
		<div class="header">
			{{ctx.Locale.Tr "Transfer Ownership"}}
		</div>
		<div class="content">
			<div class="ui warning message">
				{{ctx.Locale.Tr "- You will lose access to the repository if you transfer it to an individual user."}} <br>
				{{ctx.Locale.Tr "- You will keep access to the repository if you transfer it to an organization that you (co-)own."}} <br>
				{{ctx.Locale.Tr "- If the repository is private and is transferred to an individual user, this action makes sure that the user does have at least read permission (and changes permissions if necessary)."}} <br>
				{{ctx.Locale.Tr "- If the repository belongs to an organization, and you transfer it to another organization or individual, you will lose the links between the repository's issues and the organization's project board."}}
			</div>
			<form class="ui form" action="{{.Link}}" method="post">
				{{.CsrfTokenHtml}}
				<input type="hidden" name="action" value="transfer">
				<div class="field">
					<label>
						{{ctx.Locale.Tr "Enter the repository name as confirmation:"}}
						<span class="text red">{{.Repository.Name}}</span>
					</label>
				</div>
				<div class="required field">
					<label>{{ctx.Locale.Tr "Repository Name"}}</label>
					<input name="repo_name" required>
				</div>
				<div class="required field">
					<label for="new_owner_name">{{ctx.Locale.Tr "New Owner"}}</label>
					<input id="new_owner_name" name="new_owner_name" required>
				</div>

				<div class="actions">
					<button class="ui cancel button">{{ctx.Locale.Tr "Cancel"}}</button>
					<button class="ui red button">{{ctx.Locale.Tr "Perform Transfer"}}</button>
				</div>
			</form>
		</div>
	</div>

	<div class="ui small modal" id="delete-repo-modal">
		<div class="header">
			{{ctx.Locale.Tr "Delete This Repository"}}
		</div>
		<div class="content">
			<div class="ui warning message">
				{{ctx.Locale.Tr "- This operation <strong>CANNOT</strong> be undone."}}<br>
				{{ctx.Locale.Tr "- This operation will permanently delete the <strong>%s</strong> repository, including code, issues, comments, wiki data and collaborator settings." .Repository.FullName}}
				{{if .Repository.NumForks}}<br>
				{{ctx.Locale.Tr "- Forks of this repository will become independent after deletion."}}
				{{end}}
			</div>
			<form class="ui form" action="{{.Link}}" method="post">
				{{.CsrfTokenHtml}}
				<input type="hidden" name="action" value="delete">
				<div class="field">
					<label>
						{{ctx.Locale.Tr "Enter the repository name as confirmation:"}}
						<span class="text red">{{.Repository.Name}}</span>
					</label>
				</div>
				<div class="required field">
					<label for="repo_name_to_delete">{{ctx.Locale.Tr "Repository Name"}}</label>
					<input id="repo_name_to_delete" name="repo_name" required>
				</div>

				<div class="actions">
					<button class="ui cancel button">{{ctx.Locale.Tr "Cancel"}}</button>
					<button class="ui red button">{{ctx.Locale.Tr "Delete Repository"}}</button>
				</div>
			</form>
		</div>
	</div>

	{{if not .Repository.IsFork}}
		<div class="ui g-modal-confirm modal" id="visibility-repo-modal">
			<div class="header">
				{{ctx.Locale.Tr "Visibility"}}
			</div>
			<div class="content">
					{{if .Repository.IsPrivate}}
						<p>{{ctx.Locale.Tr "<strong>Changing the visibility to public will:</strong>"}}</p>
						<ul>
							<li>{{ctx.Locale.Tr "Make the repo visible to anyone."}}</li>
						</ul>
					{{else}}
						<p>{{ctx.Locale.Tr "<strong>Changing the visibility to private will:</strong>"}}</p>
						<ul>
							<li>{{ctx.Locale.Tr "Make the repo visible only to allowed members."}}</li>
							<li>{{ctx.Locale.Tr "May remove the relationship between it and <strong>forks</strong>, <strong>watchers</strong>, and <strong>stars</strong>."}}{{if .Repository.NumForks}}<span class="text red">{{ctx.Locale.Tr "(Changing this will affect all forks.)"}}</span>{{end}}</li>
						</ul>
					{{end}}
			</div>
			<form action="{{.Link}}" method="post">
				{{.CsrfTokenHtml}}
				<input type="hidden" name="action" value="visibility">
				<input type="hidden" name="repo_id" value="{{.Repository.ID}}">
				{{template "base/modal_actions_confirm" .}}
			</form>
		</div>
	{{end}}

	{{if .Repository.UnitEnabled ctx ctx.Consts.RepoUnitTypeWiki}}
	<div class="ui small modal" id="delete-wiki-modal">
		<div class="header">
			{{ctx.Locale.Tr "Delete Wiki Data"}}
		</div>
		<div class="content">
			<div class="ui warning message">
				{{ctx.Locale.Tr "- This operation <strong>CANNOT</strong> be undone."}}<br>
				{{ctx.Locale.Tr "- This will permanently delete and disable the repository wiki for %s." .Repository.Name}}
			</div>
			<form class="ui form" action="{{.Link}}" method="post">
				{{.CsrfTokenHtml}}
				<input type="hidden" name="action" value="delete-wiki">
				<div class="field">
					<label>
						{{ctx.Locale.Tr "Enter the repository name as confirmation:"}}
						<span class="text red">{{.Repository.Name}}</span>
					</label>
				</div>
				<div class="required field">
					<label>{{ctx.Locale.Tr "Repository Name"}}</label>
					<input name="repo_name" required>
				</div>

				<div class="actions">
					<button class="ui cancel button">{{ctx.Locale.Tr "Cancel"}}</button>
					<button class="ui red button">{{ctx.Locale.Tr "Delete Wiki Data"}}</button>
				</div>
			</form>
		</div>
	</div>
	{{end}}

	{{if not .Repository.IsMirror}}
		<div class="ui g-modal-confirm modal" id="archive-repo-modal">
			<div class="header">
				{{if .Repository.IsArchived}}
					{{ctx.Locale.Tr "Unarchive this repo"}}
				{{else}}
					{{ctx.Locale.Tr "Archive This Repo"}}
				{{end}}
			</div>
			<div class="content">
				<p>
					{{if .Repository.IsArchived}}
						{{ctx.Locale.Tr "Unarchiving the repo will restore its ability to receive commits and pushes, as well as new issues and pull requests."}}
					{{else}}
						{{ctx.Locale.Tr "Archiving the repo will make it entirely read-only. It will be hidden from the dashboard. Nobody (not even you!) will be able to make new commits, or open any issues or pull requests."}}
					{{end}}
				</p>
			</div>
			<form action="{{.Link}}" method="post">
				{{.CsrfTokenHtml}}
				<input type="hidden" name="action" value="{{if .Repository.IsArchived}}unarchive{{else}}archive{{end}}">
				<input type="hidden" name="repo_id" value="{{.Repository.ID}}">
				{{template "base/modal_actions_confirm" .}}
			</form>
		</div>
	{{end}}
{{end}}

{{template "repo/settings/push_mirror_sync_modal" .}}
