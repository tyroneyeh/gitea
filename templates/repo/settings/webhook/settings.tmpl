{{/* Template attributes:
- BaseLink: Base URL for the repository settings
- WebHook: Webhook object containing details about the webhook
- UseAuthorizationHeader: optional or required
- UseRequestSecret: optional or required
*/}}
{{$isNew := not .Webhook.ID}}

<div class="inline field">
	<div class="ui checkbox">
		<input name="active" type="checkbox" {{if or $isNew .Webhook.IsActive}}checked{{end}}>
		<label>{{ctx.Locale.Tr "Active"}}</label>
		<span class="help">{{ctx.Locale.Tr "Information about triggered events will be sent to this webhook URL."}}</span>
	</div>
</div>

<!-- Authorization Header -->
{{if .UseAuthorizationHeader}}
	{{$attributeValid := or (eq .UseAuthorizationHeader "optional") (eq .UseAuthorizationHeader "required")}}
	{{if not $attributeValid}}<div class="ui error message">Invalid UseAuthorizationHeader: {{.UseAuthorizationHeader}}}</div>{{end}}
	{{$required := eq .UseAuthorizationHeader "required"}}
	<div class="field {{if $required}}required{{end}}">
		<label>{{ctx.Locale.Tr "Authorization Header"}}</label>
		<input name="authorization_header" type="text" value="{{.Webhook.HeaderAuthorization}}" {{if $required}}required placeholder="Bearer $access_token"{{end}}>
		{{if not $required}}
			<span class="help">{{ctx.Locale.Tr "Will be included as authorization header for requests when present. Examples: %s." (HTMLFormat "<code>%s</code>, <code>%s</code>" "Bearer token123456" "Basic YWxhZGRpbjpvcGVuc2VzYW1l")}}</span>
		{{end}}
	</div>
{{end}}

<!-- Secret -->
{{if .UseRequestSecret}}
	{{$attributeValid := or (eq .UseRequestSecret "optional") (eq .UseRequestSecret "required")}}
	{{if not $attributeValid}}<div class="ui error message">Invalid UseRequestSecret: {{.UseRequestSecret}}}</div>{{end}}
	{{$required := eq .UseRequestSecret "required"}}
	<div class="field {{if $required}}required{{end}}">
		<label>{{ctx.Locale.Tr "Secret"}}</label>
		<input name="secret" type="password" value="{{.Webhook.Secret}}" autocomplete="off" {{if $required}}required{{end}}>
		<span class="help">{{ctx.Locale.Tr "If the webhook server supports using secret, you can follow the webhook's manual and fill in a secret here."}}</span>
	</div>
{{end}}

<!-- Branch filter -->
<div class="field">
	<label>{{ctx.Locale.Tr "Branch filter"}}</label>
	<input name="branch_filter" type="text" value="{{or .Webhook.BranchFilter "*"}}">
	<span class="help">
		{{ctx.Locale.Tr "Branch (and ref name) allowlist for push, branch creation and branch deletion events, specified as glob pattern. If empty or <code>*</code>, events for all branches and tags are reported."}}
		{{ctx.Locale.Tr "Use <code>refs/heads/</code> or <code>refs/tags/</code> prefix to match full ref names."}}
		{{ctx.Locale.Tr "See <a href=\"%[1]s\">%[2]s</a> documentation for syntax." "https://pkg.go.dev/github.com/gobwas/glob#Compile" "github.com/gobwas/glob"}}
		<ul>
			<li><code>main</code></li>
			<li><code>{main,feature/*}</code></li>
			<li><code>{refs/heads/feature/*,refs/tags/release/*}</code></li>
		</ul>
	</span>
</div>

<div class="field">
	<h4>{{ctx.Locale.Tr "Trigger On:"}}</h4>
	<div class="grouped event type fields">
		<div class="field">
			<div class="ui radio non-events checkbox">
				<input name="events" type="radio" value="push_only" {{if or $isNew .Webhook.PushOnly}}checked{{end}}>
				<label>{{ctx.Locale.Tr "Push Events"}}</label>
			</div>
		</div>
		<div class="field">
			<div class="ui radio non-events checkbox">
				<input name="events" type="radio" value="send_everything" {{if .Webhook.SendEverything}}checked{{end}}>
				<label>{{ctx.Locale.Tr "All Events"}}</label>
			</div>
		</div>
		<div class="field">
			<div class="ui radio events checkbox">
				<input name="events" type="radio" value="choose_events" {{if .Webhook.ChooseEvents}}checked{{end}}>
				<label>{{ctx.Locale.Tr "Custom Events…"}}</label>
			</div>
		</div>
	</div>

	<div class="events fields ui grid {{if not .Webhook.ChooseEvents}}tw-hidden{{end}}">
		<!-- Repository Events -->
		<div class="fourteen wide column">
			<label>{{ctx.Locale.Tr "Repository Events"}}</label>
		</div>
		<!-- Create -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="create" type="checkbox" {{if .Webhook.HookEvents.Get "create"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Create"}}</label>
					<span class="help">{{ctx.Locale.Tr "Branch or tag created."}}</span>
				</div>
			</div>
		</div>
		<!-- Delete -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="delete" type="checkbox" {{if .Webhook.HookEvents.Get "delete"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Delete"}}</label>
					<span class="help">{{ctx.Locale.Tr "Branch or tag deleted."}}</span>
				</div>
			</div>
		</div>
		<!-- Fork -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="fork" type="checkbox" {{if .Webhook.HookEvents.Get "fork"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Fork"}}</label>
					<span class="help">{{ctx.Locale.Tr "Repository forked."}}</span>
				</div>
			</div>
		</div>
		<!-- Push -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="push" type="checkbox" {{if .Webhook.HookEvents.Get "push"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Push"}}</label>
					<span class="help">{{ctx.Locale.Tr "Git push to a repository."}}</span>
				</div>
			</div>
		</div>
		<!-- Repository -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="repository" type="checkbox" {{if .Webhook.HookEvents.Get "repository"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Repository"}}</label>
					<span class="help">{{ctx.Locale.Tr "Repository created or deleted."}}</span>
				</div>
			</div>
		</div>
		<!-- Release -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="release" type="checkbox" {{if .Webhook.HookEvents.Get "release"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Release"}}</label>
					<span class="help">{{ctx.Locale.Tr "Release published, updated or deleted in a repository."}}</span>
				</div>
			</div>
		</div>
		<!-- Package -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="package" type="checkbox" {{if .Webhook.HookEvents.Get "package"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Package"}}</label>
					<span class="help">{{ctx.Locale.Tr "Package created or deleted in a repository."}}</span>
				</div>
			</div>
		</div>

		<!-- Wiki -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="wiki" type="checkbox" {{if .Webhook.HookEvents.Get "wiki"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Wiki"}}</label>
					<span class="help">{{ctx.Locale.Tr "Wiki page created, renamed, edited or deleted."}}</span>
				</div>
			</div>
		</div>

		<!-- Status -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="status" type="checkbox" {{if .Webhook.HookEvents.Get "status"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Statuses"}}</label>
					<span class="help">{{ctx.Locale.Tr "Commit Status updated from the API."}}</span>
				</div>
			</div>
		</div>

		<!-- Issue Events -->
		<div class="fourteen wide column">
			<label>{{ctx.Locale.Tr "Issue Events"}}</label>
		</div>
		<!-- Issues -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="issues" type="checkbox" {{if .Webhook.HookEvents.Get "issues"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Issues"}}</label>
					<span class="help">{{ctx.Locale.Tr "Issue opened, closed, reopened, edited or deleted."}}</span>
				</div>
			</div>
		</div>
		<!-- Issue Assign -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="issue_assign" type="checkbox" {{if .Webhook.HookEvents.Get "issue_assign"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Issue Assigned"}}</label>
					<span class="help">{{ctx.Locale.Tr "Issue assigned or unassigned."}}</span>
				</div>
			</div>
		</div>
		<!-- Issue Label -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="issue_label" type="checkbox" {{if .Webhook.HookEvents.Get "issue_label"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Issue Labeled"}}</label>
					<span class="help">{{ctx.Locale.Tr "Issue labels updated or cleared."}}</span>
				</div>
			</div>
		</div>
		<!-- Issue Milestone -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="issue_milestone" type="checkbox" {{if .Webhook.HookEvents.Get "issue_milestone"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Issue Milestoned"}}</label>
					<span class="help">{{ctx.Locale.Tr "Issue milestoned or demilestoned."}}</span>
				</div>
			</div>
		</div>
		<!-- Issue Comment -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="issue_comment" type="checkbox" {{if .Webhook.HookEvents.Get "issue_comment"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Issue Comment"}}</label>
					<span class="help">{{ctx.Locale.Tr "Issue comment created, edited, or deleted."}}</span>
				</div>
			</div>
		</div>

		<!-- Pull Request Events -->
		<div class="fourteen wide column">
			<label>{{ctx.Locale.Tr "Pull Request Events"}}</label>
		</div>
		<!-- Pull Request -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="pull_request" type="checkbox" {{if .Webhook.HookEvents.Get "pull_request"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Pull Request"}}</label>
					<span class="help">{{ctx.Locale.Tr "Pull request opened, closed, reopened, edited or deleted."}}</span>
				</div>
			</div>
		</div>
		<!-- Pull Request Assign -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="pull_request_assign" type="checkbox" {{if .Webhook.HookEvents.Get "pull_request_assign"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Pull Request Assigned"}}</label>
					<span class="help">{{ctx.Locale.Tr "Pull request assigned or unassigned."}}</span>
				</div>
			</div>
		</div>
		<!-- Pull Request Label -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="pull_request_label" type="checkbox" {{if .Webhook.HookEvents.Get "pull_request_label"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Pull Request Labeled"}}</label>
					<span class="help">{{ctx.Locale.Tr "Pull request labels updated or cleared."}}</span>
				</div>
			</div>
		</div>
		<!-- Pull Request Milestone -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="pull_request_milestone" type="checkbox" {{if .Webhook.HookEvents.Get "pull_request_milestone"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Pull Request Milestoned"}}</label>
					<span class="help">{{ctx.Locale.Tr "Pull request milestoned or demilestoned."}}</span>
				</div>
			</div>
		</div>
		<!-- Pull Request Comment -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="pull_request_comment" type="checkbox" {{if .Webhook.HookEvents.Get "pull_request_comment"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Pull Request Comment"}}</label>
					<span class="help">{{ctx.Locale.Tr "Pull request comment created, edited, or deleted."}}</span>
				</div>
			</div>
		</div>
		<!-- Pull Request Review -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="pull_request_review" type="checkbox" {{if .Webhook.HookEvents.Get "pull_request_review"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Pull Request Reviewed"}}</label>
					<span class="help">{{ctx.Locale.Tr "Pull request approved, rejected, or review comment."}}</span>
				</div>
			</div>
		</div>
		<!-- Pull Request Sync -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="pull_request_sync" type="checkbox" {{if .Webhook.HookEvents.Get "pull_request_sync"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Pull Request Synchronized"}}</label>
					<span class="help">{{ctx.Locale.Tr "Pull request synchronized."}}</span>
				</div>
			</div>
		</div>
		<!-- Pull Request Review Request -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="pull_request_review_request" type="checkbox" {{if .Webhook.HookEvents.Get "pull_request_review_request"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Pull Request Review Requested"}}</label>
					<span class="help">{{ctx.Locale.Tr "Pull request review requested or review request removed."}}</span>
				</div>
			</div>
		</div>
		<!-- Workflow Events -->
		<div class="fourteen wide column">
			<label>{{ctx.Locale.Tr "Workflow Events"}}</label>
		</div>
		<!-- Workflow Run Event -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="workflow_run" type="checkbox" {{if .Webhook.HookEvents.Get "workflow_run"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Workflow Run"}}</label>
					<span class="help">{{ctx.Locale.Tr "Gitea Actions Workflow run queued, waiting, in progress, or completed."}}</span>
				</div>
			</div>
		</div>
		<!-- Workflow Job Event -->
		<div class="seven wide column">
			<div class="field">
				<div class="ui checkbox">
					<input name="workflow_job" type="checkbox" {{if .Webhook.HookEvents.Get "workflow_job"}}checked{{end}}>
					<label>{{ctx.Locale.Tr "Workflow Jobs"}}</label>
					<span class="help">{{ctx.Locale.Tr "Gitea Actions Workflow job queued, waiting, in progress, or completed."}}</span>
				</div>
			</div>
		</div>
	</div>
</div>

<div class="field">
	{{if $isNew}}
		<button class="ui primary button">{{ctx.Locale.Tr "Add Webhook"}}</button>
	{{else}}
		<button class="ui primary button">{{ctx.Locale.Tr "Update Webhook"}}</button>
		<a class="ui red button link-action"
			data-url="{{.BaseLink}}/delete?id={{.Webhook.ID}}"
			data-modal-confirm="{{ctx.Locale.Tr "Removing a webhook deletes its settings and delivery history. Continue?"}}"
		>{{ctx.Locale.Tr "Remove Webhook"}}</a>
	{{end}}
</div>
