{{/* Template Attributes:
* Release: the release
* IsLatest: boolean indicating whether this is the latest release, optional
*/}}
{{if .IsLatest}}
	<span class="ui green label">{{ctx.Locale.Tr "Latest"}}</span>
{{else if .Release.IsDraft}}
	<span class="ui yellow label">{{ctx.Locale.Tr "Draft"}}</span>
{{else if .Release.IsPrerelease}}
	<span class="ui orange label">{{ctx.Locale.Tr "Pre-Release"}}</span>
{{else if (not .Release.IsTag)}}
	<span class="ui green label">{{ctx.Locale.Tr "Stable"}}</span>
{{end}}
