{{if .dependencies}}
<p><strong>{{.title}}</strong></p>
<table class="ui single line very basic table">
	<thead>
		<tr>
			<th class="eleven wide">{{ctx.Locale.Tr "ID"}}</th>
			<th class="five wide">{{ctx.Locale.Tr "Version"}}</th>
		</tr>
	</thead>
	<tbody>
		{{range $dependency, $version := .dependencies}}
		<tr>
			<td>{{$dependency}}</td>
			<td>{{$version}}</td>
		</tr>
		{{end}}
	</tbody>
</table>
{{end}}
