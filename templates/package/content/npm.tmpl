{{if eq .PackageDescriptor.Package.Type "npm"}}
	<h4 class="ui top attached header">{{ctx.Locale.Tr "Installation"}}</h4>
	<div class="ui attached segment">
		<div class="ui form">
			<div class="field">
				<label>{{svg "octicon-code"}} {{ctx.Locale.Tr "Set up this registry in your project <code>.npmrc</code> file:"}}</label>
				<div class="markup"><pre class="code-block"><code>{{if .PackageDescriptor.Metadata.Scope}}{{.PackageDescriptor.Metadata.Scope}}:{{end}}registry=<origin-url data-url="{{AppSubUrl}}/api/packages/{{.PackageDescriptor.Owner.Name}}/npm/"></origin-url></code></pre></div>
			</div>
			<div class="field">
				<label>{{svg "octicon-terminal"}} {{ctx.Locale.Tr "To install the package using npm, run the following command:"}}</label>
				<div class="markup"><pre class="code-block"><code>npm install {{.PackageDescriptor.Package.Name}}@{{.PackageDescriptor.Version.Version}}</code></pre></div>
			</div>
			<div class="field">
				<label>{{svg "octicon-code"}} {{ctx.Locale.Tr "or add it to the package.json file:"}}</label>
				<div class="markup"><pre class="code-block"><code>&quot;{{.PackageDescriptor.Package.Name}}&quot;: &quot;{{.PackageDescriptor.Version.Version}}&quot;</code></pre></div>
			</div>
			<div class="field">
				<label>{{ctx.Locale.Tr "For more information on the %s registry, see <a target=\"_blank\" rel=\"noopener noreferrer\" href=\"%s\">the documentation</a>." "npm" "https://docs.gitea.com/usage/packages/npm/"}}</label>
			</div>
		</div>
	</div>

	{{if or .PackageDescriptor.Metadata.Description .PackageDescriptor.Metadata.Readme}}
		<h4 class="ui top attached header">{{ctx.Locale.Tr "About this package"}}</h4>
		<div class="ui attached segment">
			{{if .PackageDescriptor.Metadata.Readme}}
			<div class="markup markdown">
				{{ctx.RenderUtils.MarkdownToHtml .PackageDescriptor.Metadata.Readme}}
			</div>
			{{else if .PackageDescriptor.Metadata.Description}}
				{{.PackageDescriptor.Metadata.Description}}
			{{end}}
		</div>
	{{end}}

	{{if or .PackageDescriptor.Metadata.Dependencies .PackageDescriptor.Metadata.DevelopmentDependencies .PackageDescriptor.Metadata.PeerDependencies .PackageDescriptor.Metadata.OptionalDependencies}}
		<h4 class="ui top attached header">{{ctx.Locale.Tr "Dependencies"}}</h4>
		<div class="ui attached segment">
			<div class="ui list">
				{{template "package/content/npm_dependencies" dict "root" $ "dependencies" .PackageDescriptor.Metadata.Dependencies "title" (ctx.Locale.Tr "Dependencies")}}
				{{template "package/content/npm_dependencies" dict "root" $ "dependencies" .PackageDescriptor.Metadata.DevelopmentDependencies "title" (ctx.Locale.Tr "Development Dependencies")}}
				{{template "package/content/npm_dependencies" dict "root" $ "dependencies" .PackageDescriptor.Metadata.PeerDependencies "title" (ctx.Locale.Tr "Peer Dependencies")}}
				{{template "package/content/npm_dependencies" dict "root" $ "dependencies" .PackageDescriptor.Metadata.OptionalDependencies "title" (ctx.Locale.Tr "Optional Dependencies")}}
			</div>
		</div>
	{{end}}

	{{if .PackageDescriptor.Metadata.BundleDependencies}}
		<h4 class="ui top attached header">{{ctx.Locale.Tr "Bundled Dependencies"}}</h4>
		<div class="ui attached segment">
			{{range .PackageDescriptor.Metadata.BundleDependencies}}
				{{.}}
			{{end}}
		</div>
	{{end}}

	{{if .PackageDescriptor.Metadata.Keywords}}
		<h4 class="ui top attached header">{{ctx.Locale.Tr "Keywords"}}</h4>
		<div class="ui attached segment">
			{{range .PackageDescriptor.Metadata.Keywords}}
				{{.}}
			{{end}}
		</div>
	{{end}}
{{end}}
