{{if eq .PackageDescriptor.Package.Type "arch"}}
	<h4 class="ui top attached header">{{ctx.Locale.Tr "Installation"}}</h4>
	<div class="ui attached segment">
		<div class="ui form">
			<div class="field">
				<label>{{svg "octicon-gear"}} {{ctx.Locale.Tr "Add server with related repository and architecture to <code>/etc/pacman.conf</code>:"}}</label>
				<div class="markup"><pre class="code-block"><code>{{range $i, $repo := .Repositories}}{{if $i}}
{{end}}[{{$repo}}]
SigLevel = Optional TrustAll
Server = <origin-url data-url="{{AppSubUrl}}/api/packages/{{$.PackageDescriptor.Owner.Name}}/arch/$repo/$arch"></origin-url>
{{end}}</code></pre></div>
			</div>
			<div class="field">
				<label>{{svg "octicon-sync"}} {{ctx.Locale.Tr "Sync package with pacman:"}}</label>
				<div class="markup"><pre class="code-block"><code>pacman -Sy {{.PackageDescriptor.Package.LowerName}}</code></pre></div>
			</div>
			<div class="field">
				<label>{{ctx.Locale.Tr "For more information on the %s registry, see <a target=\"_blank\" rel=\"noopener noreferrer\" href=\"%s\">the documentation</a>." "Arch" "https://docs.gitea.com/usage/packages/arch/"}}</label>
			</div>
		</div>
	</div>

	<h4 class="ui top attached header">{{ctx.Locale.Tr "Repository Info"}}</h4>
	<div class="ui attached segment">
		<table class="ui single line very basic table">
			<tbody>
				<tr>
					<td class="collapsing"><h5>{{ctx.Locale.Tr "Repositories"}}</h5></td>
					<td>{{StringUtils.Join .Repositories ", "}}</td>
				</tr>
				<tr>
					<td class="collapsing"><h5>{{ctx.Locale.Tr "Architectures"}}</h5></td>
					<td>{{StringUtils.Join .Architectures ", "}}</td>
				</tr>
			</tbody>
		</table>
	</div>

	{{if .PackageDescriptor.Metadata.Description}}
		<h4 class="ui top attached header">{{ctx.Locale.Tr "About this package"}}</h4>
		<div class="ui attached segment">{{.PackageDescriptor.Metadata.Description}}</div>
	{{end}}
{{end}}
