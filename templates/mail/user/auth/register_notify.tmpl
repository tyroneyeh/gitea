<!DOCTYPE html>
<html>
<head>
	<meta http-equiv="Content-Type" content="text/html; charset=utf-8">
	<meta name="format-detection" content="telephone=no,date=no,address=no,email=no,url=no">
	<title>{{.locale.Tr "%[1]s, welcome to %[2]s" (.DisplayName|DotEscape) AppName}}</title>
</head>

{{$set_pwd_url := printf "%[1]suser/forgot_password" AppUrl}}
<body>
	<p>{{.locale.Tr "Hi <b>%s</b>," (.DisplayName|DotEscape)}}</p><br>
	<p>{{.locale.Tr "This is your registration confirmation email for %s!" AppName}}</p><br>
	<p>{{.locale.Tr "You can now log in via username: %s." .Username}}</p><p><a href="{{AppUrl}}user/login">{{AppUrl}}user/login</a></p><br>
	<p>{{.locale.Tr "If this account has been created for you, please <a href=\"%s\">set your password</a> first." $set_pwd_url}}</p><br>

	<p>© <a href="{{AppUrl}}">{{AppName}}</a></p>
</body>
</html>
